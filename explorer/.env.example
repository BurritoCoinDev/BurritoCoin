# BurritoCoin Block Explorer — environment configuration
# Copy this file to .env and fill in your values before starting.
#
#   cp .env.example .env
#   nano .env
#   npm start

# ---------------------------------------------------------------------------
# Coin
# ---------------------------------------------------------------------------
BTCEXP_COIN=BRTO

# ---------------------------------------------------------------------------
# Web server
# ---------------------------------------------------------------------------
BTCEXP_HOST=127.0.0.1
BTCEXP_PORT=3002

# ---------------------------------------------------------------------------
# BurritoCoin node RPC connection
# ---------------------------------------------------------------------------
# Point these at the burritocoind instance the explorer will query.
# The RPC port for mainnet is 9226 (P2P is 9227).
BTCEXP_BITCOIND_HOST=127.0.0.1
BTCEXP_BITCOIND_PORT=9226
BTCEXP_BITCOIND_USER=your_rpc_username
BTCEXP_BITCOIND_PASS=your_rpc_password

# For regtest / local testing:
# BTCEXP_BITCOIND_PORT=19553
# BTCEXP_BITCOIND_USER=user
# BTCEXP_BITCOIND_PASS=pass

# ---------------------------------------------------------------------------
# Address / UTXO lookup
# Requires burritocoind to be started with -addressindex=1 -txindex=1
# ---------------------------------------------------------------------------
# Options: none | electrumx | blockbook | insight
BTCEXP_ADDRESS_API=none

# If using ElectrumX:
# BTCEXP_ELECTRUMX_SERVERS=tcp://127.0.0.1:50001

# ---------------------------------------------------------------------------
# Optional features
# ---------------------------------------------------------------------------
# Set to "false" to disable caching (useful for regtest where blocks change fast).
BTCEXP_NO_INMEMORY_RPC_CACHE=false

# Show raw transaction hex on transaction pages.
BTCEXP_UI_SHOW_RAWTXHEX=true

# Show total supply estimate on the home page.
BTCEXP_DISPLAY_CURRENCY=BRTO

# Site security — tighten for production.
BTCEXP_SITE_SECURITY_HEADER_REFERRER_POLICY=same-origin

# ---------------------------------------------------------------------------
# Privacy / access control (optional)
# ---------------------------------------------------------------------------
# Require a password to access the explorer (leave blank for open access).
# BTCEXP_BASIC_AUTH_PASSWORD=your_explorer_password

# ---------------------------------------------------------------------------
# SSL (optional — use a reverse proxy like nginx instead for production)
# ---------------------------------------------------------------------------
# BTCEXP_SECURE_SITE=false
# BTCEXP_SSL_CERT_FILE=/path/to/cert.pem
# BTCEXP_SSL_KEY_FILE=/path/to/key.pem
